{
  "name": "lumina-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @luminafe/web dev",
    "dev:full": "pnpm --filter @luminafe/web dev:full",
    "dev:pages": "pnpm --filter @luminafe/web dev:pages",
    "cli:dev": "pnpm --filter @luminafe/cli dev",
    "cli:build": "pnpm --filter @luminafe/cli build",
    "cli:pack": "npm_config_cache=/tmp/.npm-cache pnpm --filter @luminafe/cli exec npm pack --dry-run",
    "cli:publish": "npm_config_cache=/tmp/.npm-cache pnpm --filter @luminafe/cli publish --access public",
    "deploy": "pnpm --filter @luminafe/web run deploy",
    "knip": "knip"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "@types/node": "^22.14.0",
    "knip": "^5.85.0",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.5.6",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.23.24",
    "tailwind-merge": "^3.5.0"
  }
}
